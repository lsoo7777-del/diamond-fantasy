# ESPN credentials are stored per-user in httpOnly cookies (not here).
# This file is for any server-level secrets you add later.

# Optional: a secret used to sign the credential cookie
COOKIE_SECRET=change-me-to-a-random-32-char-string

# ESPN API base (do not change unless ESPN moves their endpoint)
NEXT_PUBLIC_ESPN_API_BASE=https://fantasy.espn.com/apis/v3/games/flb
